{
  "name": "ADS131M04",
  "version": "0.0.1",
  "description": "Arduino library for interfacing with the ADS131M04 ADC",
  "build": {
    "srcDir": ".",
    "includeDir": "src",
    "srcFilter": ["+<src/*>", "-<examples/*>"]
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/jeevan9s/device-libs"
  },
  "authors": [
    {
      "name": "Jeevan Sanchez",
      "maintainer": true
    }
  ],
  "frameworks": "arduino",
  "platforms": ["ststm32", "espressif32"],
  "dependencies": [
    {
      "name": "SPI",
      "version": "*"
    }
  ]
}
